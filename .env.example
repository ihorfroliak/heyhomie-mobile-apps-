# HeyHomie apps — environment template. Copy to .env and fill per environment.
# NEVER commit the real .env (see .gitignore).

# Backend base URLs (override packages/api/config.ts presets)
EXPO_PUBLIC_GO_API_URL=https://heyhomie-api.dev.stuzer.link
EXPO_PUBLIC_RAILS_API_URL=https://heyhomie-api.dev.stuzer.link

# Analytics (public measurement id — not a secret, but kept out of git)
EXPO_PUBLIC_GA_ID=

# Payments (publishable key only — never the secret key)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
