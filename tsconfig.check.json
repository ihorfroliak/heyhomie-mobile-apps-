{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["packages/domain/*.ts", "packages/api/*.ts", "packages/analytics/*.ts"],
  "exclude": ["**/*.test.ts"]
}
