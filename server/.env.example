# HeyHomie orders backend — copy to .env
DATABASE_URL=postgres://postgres:postgres@localhost:5432/heyhomie
PORT=8090

# Auth (Build 05). Secret signs/verifies bearer tokens — set a real one in prod.
AUTH_SECRET=dev-secret-change-me
# 1 = enable x-dev-* header fallback + GET /dev/token (LOCAL ONLY).
AUTH_DEV_MODE=1
